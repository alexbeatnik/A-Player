{
  // The tests reach into both processes at once — store.test.ts covers main,
  // player.test.ts covers the renderer — so neither of the two app configs can
  // see all of them. This one spans everything and only ever typechecks.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  // Only the tests are listed: whatever they import is pulled into the program
  // automatically, and the app sources are already covered by the two configs
  // above. src/preload/index.d.ts has to be named explicitly — it declares
  // window.aplayer, and a wildcard would drop it in favour of index.ts.
  "include": ["tests/**/*", "src/preload/index.d.ts"]
}
